# Copy this file to .env and fill in a key to enable full LLM tool-calling mode.
# Without either key, the API still works fully via the rule-based fallback path.

# PRIMARY provider - Gemini has a genuinely free tier (no credit card,
# ~1,500 requests/day on Flash). Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# SECONDARY provider (optional) - used automatically if GEMINI_API_KEY is
# absent, or if the Gemini call itself fails.
ANTHROPIC_API_KEY=sk-ant-your-key-here
